CURRENCY="INR"
JWT_SECRET=<generate_a_strong_random_secret_key>

# Admin Panel Credentials
ADMIN_EMAIL=<your_admin_email>
ADMIN_PASSWORD=<your_secure_admin_password>

# Database
# For Local MongoDB Compass:
# MONGODB_URI=mongodb://localhost:27017/healthsystem
# For MongoDB Atlas (Cloud):
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<appname>

# Cloudinary Setup (required)
CLOUDINARY_NAME=<your_cloudinary_cloud_name>
CLOUDINARY_API_KEY=<your_cloudinary_api_key>
CLOUDINARY_SECRET_KEY=<your_cloudinary_secret_key>

# Razorpay Payment Integration
RAZORPAY_KEY_ID=<your_razorpay_key_id>
RAZORPAY_KEY_SECRET=<your_razorpay_key_secret>

# Stripe Payment Integration
STRIPE_SECRET_KEY=<your_stripe_secret_key>

# Meta WhatsApp Cloud API Configuration
WHATSAPP_ACCESS_TOKEN=<your_whatsapp_access_token>
WHATSAPP_PHONE_NUMBER_ID=<your_whatsapp_phone_number_id>
WHATSAPP_BUSINESS_ACCOUNT_ID=<your_whatsapp_business_account_id>
WHATSAPP_VERIFY_TOKEN=<your_custom_verify_token>
WHATSAPP_PROVIDER=meta

# AI API Keys
GEMINI_API_KEY=<your_gemini_api_key>
OPENAI_API_KEY=<your_openai_api_key>

# Email Configuration (Brevo/Sendinblue)
BERVO_API_KEY=<your_brevo_api_key>
BERVO_SENDER_EMAIL=<your_sender_email>
BERVO_APP_NAME=medichain

# Platform Configuration
PLATFORM_FEE_PERCENTAGE=5    # Default: 5%
GST_PERCENTAGE=18            # Default: 18%

# Frontend URL (for payment callbacks)
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
